# YouTube Data API v3 key (required)
# Get one free at: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=your_youtube_api_key_here

# Groq API key (required for AI summary on home page)
# Get one free (no credit card) at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Admin password protecting the /admin notes panel (required to add manual
# AI-summary notes). Choose any strong secret value.
ADMIN_PASSWORD=change_me_to_a_strong_secret

# Upstash Redis — required in production so admin notes survive Vercel redeploys.
# Free tier (10 000 commands/day, 256 MB) is more than enough.
# Create a free database at https://upstash.com, then paste the REST URL and token.
# When using the Vercel Marketplace Upstash integration these are set automatically.
# Leave these unset in local .env — the app will use the filesystem instead.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=